**Public Sentiment Toward Electric Vehicles in Australia**

Team: Ansh Anand Parekh (s4060237), Disha Dogra (s4091900), Syna Arora (s4109652)

This notebook integrates outputs from notebooks 01–04 to answer the RQ:
> "How has public sentiment toward EVs evolved in Australian Reddit communities,
> and what network structures and topics drive the EV conversation?"


import os, json
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import networkx as nx
from collections import Counter

PROCESSED = "../data/processed"
FIGURES   = "../reports/figures"
os.makedirs(FIGURES, exist_ok=True)
sns.set(style="whitegrid")


posts    = pd.read_csv(f"{PROCESSED}/posts_clean.csv")
comments = pd.read_csv(f"{PROCESSED}/comments_clean.csv")
sentiment = pd.read_csv(f"{PROCESSED}/comments_sentiment.csv")     # from notebook 04
topics    = pd.read_csv(f"{PROCESSED}/comments_topics.csv")        # from notebook 04
centrality = pd.read_csv(f"{PROCESSED}/centrality.csv")            # from notebook 03
community  = pd.read_csv(f"{PROCESSED}/community_assignments.csv") # from notebook 03

df = (comments
      .merge(sentiment[['comment_id','compound']], on='comment_id', how='left')
      .merge(topics[['comment_id','topic']],       on='comment_id', how='left')
      .merge(community[['author_anon','community']], on='author_anon', how='left'))
df['year_month'] = pd.to_datetime(df['created_dt']).dt.to_period('M').astype(str)


## Headline numbers
- 311 posts, 84,281 clean comments, 23,561 unique anonymised users
- Date range 2023-03-23 to 2025-12-30
- Network: 16,450 nodes, 47,860 edges, 48 communities, modularity Q = 0.4887
- Dominant terms: tesla (130), car (43), musk (39), elon (31), ev (30)


plt.figure(figsize=(8,4))
sns.boxplot(data=df, x='subreddit', y='compound')
plt.axhline(0, color='red', linestyle='--', alpha=.5)
plt.title("Sentiment distribution by subreddit")
plt.savefig(f"{FIGURES}/05_sentiment_by_subreddit.png", dpi=150); plt.show()


top_comms = df['community'].value_counts().head(15).index
sub = df[df['community'].isin(top_comms)].groupby('community')['compound'].mean().sort_values()
sub.plot(kind='barh', figsize=(8,6), color='steelblue')
plt.axvline(0, color='red', linestyle='--')
plt.title("Mean sentiment by Louvain community (top 15 by size)")
plt.savefig(f"{FIGURES}/05_sentiment_by_community.png", dpi=150); plt.show()


topic_sent = df.groupby('topic')['compound'].mean().sort_values()
topic_sent.plot(kind='barh', figsize=(8,5), color='coral')
plt.axvline(0, color='red', linestyle='--')
plt.title("Mean sentiment by LDA topic")
plt.savefig(f"{FIGURES}/05_sentiment_by_topic.png", dpi=150); plt.show()


top_users = centrality.nlargest(10, 'pagerank')['user'].tolist()
infl = (df[df['author_anon'].isin(top_users)]
        .groupby('author_anon')
        .agg(comments=('comment_id','count'),
             mean_sent=('compound','mean'))
        .reset_index()
        .sort_values('mean_sent'))
infl


prev = (df.groupby(['year_month','topic']).size()
          .unstack(fill_value=0)
          .apply(lambda r: r/r.sum(), axis=1))
prev.plot.area(figsize=(12,5), colormap='tab20')
plt.title("Topic prevalence over time (share of comments)")
plt.savefig(f"{FIGURES}/05_topic_prevalence_over_time.png", dpi=150); plt.show()


heat = (df[df['community'].isin(top_comms)]
        .groupby(['community','topic']).size()
        .unstack(fill_value=0))
heat = heat.div(heat.sum(axis=1), axis=0)
plt.figure(figsize=(10,6))
sns.heatmap(heat, cmap='magma')
plt.title("Topic distribution within top 15 communities")
plt.savefig(f"{FIGURES}/05_community_topic_heatmap.png", dpi=150); plt.show()


