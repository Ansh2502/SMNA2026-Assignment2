# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/

# API Keys and credentials — NEVER commit these
secrets.py
api_keys.py
.env

# Data files (too large for GitHub — submit sample only)
